# Emilio Castro's git configuration
# Managed by chezmoi

[user]
    name = {{ .name }}
    email = {{ .email }}
{{ if .gitSigningKey }}
    signingkey = {{ .gitSigningKey }}
{{ end }}

[github]
    user = {{ .github }}

[core]
    editor = nvim
    pager = delta
    autocrlf = input

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true
    writeCommitGraph = true     # speeds up git log on large repos

[merge]
    tool = nvimdiff
    conflictstyle = zdiff3      # upgraded from diff3; shows base in 3-way conflicts

[diff]
    tool = nvimdiff
    colorMoved = default

[branch]
    sort = -committerdate       # most recent branches first in git branch -l

[rerere]
    enabled = true              # remember and replay recorded conflict resolutions
{{ if .gitSigningKey }}
[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers

[commit]
    gpgsign = true

[tag]
    gpgsign = true
{{ end }}
[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true

[interactive]
    diffFilter = delta --color-only

[alias]
    # Short aliases
    st = status
    co = checkout
    br = branch
    ci = commit
    df = diff
    dc = diff --cached
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD

    # Teaching helpers
    undo = reset --soft HEAD~1
    amend = commit --amend --no-edit
    unstage = reset HEAD --
    discard = checkout --

    # Branch management
    bd = branch -d
    bD = branch -D

    # Review helpers
    review = log --oneline --reverse origin/main..HEAD
    files = diff --name-only origin/main...HEAD

[color]
    ui = auto

[credential]
    helper = osxkeychain

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
