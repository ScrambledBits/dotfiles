# Managed by chezmoi: https://www.chezmoi.io/
# Source: {{ .chezmoi.sourceDir }}

# =============================================================================
# 1. Environment & Paths (External Files)
# =============================================================================
# Create these manually: ~/.config/shell/.env, api_keys.env, paths
if [[ -f "$HOME/.config/shell/.env" ]]; then
    source "$HOME/.config/shell/.env"
fi

if [[ -f "$HOME/.config/shell/api_keys.env" ]]; then
    source "$HOME/.config/shell/api_keys.env"
fi

if [[ -f "$HOME/.config/shell/paths" ]]; then
    source "$HOME/.config/shell/paths"
fi

# =============================================================================
# 2. Completion Cache Path (OMZ manages compinit)
# =============================================================================
export ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zcompdump-${ZSH_VERSION}"

# Homebrew prefix, captured once (each $(brew --prefix) forks a subprocess)
command -v brew &>/dev/null && BREW_PREFIX="$(brew --prefix)"

# =============================================================================
# 3. Oh My Zsh Configuration
# =============================================================================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""  # Disabled — using Starship instead

setopt hist_ignore_all_dups inc_append_history
ENABLE_CORRECTION="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
HIST_STAMPS="dd/mm/yyyy"

# Auto-update settings
zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 13
zstyle ':completion:::::' completer _complete _approximate
zstyle ':completion:*:approximate:*' max-errors 2

# Plugins (tailored to your actual workflow)
plugins=(
    alias-finder
    aliases
    ansible
    brew
    colored-man-pages
    docker
    docker-compose
    git
    git-extras
    gitignore
    history
    kubectl
    macos
    man
    mise
    terraform
)

# Load OMZ
source "$ZSH/oh-my-zsh.sh"

[[ -f "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
    source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
[[ -f "$BREW_PREFIX/opt/zsh-fast-syntax-highlighting/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]] && \
    source "$BREW_PREFIX/opt/zsh-fast-syntax-highlighting/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"

# =============================================================================
# 4. Prompt (Starship)
# =============================================================================
# OS icon rendered by the [env_var.STARSHIP_DISTRO] module in starship.toml
export STARSHIP_DISTRO="{{ if eq .chezmoi.os "darwin" }}{{ else }}{{ end }}"
eval "$(starship init zsh)"

# =============================================================================
# 5. Version Managers & Language Environments
# =============================================================================
# mise (primary version manager — replaces nvm, pyenv, rbenv)
eval "$(mise activate zsh)"

# direnv (per-directory environment variables)
eval "$(direnv hook zsh)"

# Rust/Cargo environment (installed via mise)
if [[ -f "$HOME/.cargo/env" ]]; then
    source "$HOME/.cargo/env"
fi

# =============================================================================
# 6. Shell Enhancements
# =============================================================================
# zoxide (smart cd — already in your setup)
eval "$(zoxide init zsh)"

# FZF configuration (already in your setup)
command -v fzf &>/dev/null && source <(fzf --zsh)
export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git/*"'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# =============================================================================
# 7. Aliases & Shortcuts
# =============================================================================

# Editor
alias vim='nvim'

# Modern Core Utils (Bat/Eza)
# k*/tf* aliases come from the OMZ kubectl/terraform plugins above
alias cat='bat'
alias grep='batgrep --terminal-width=200 --no-snip'
alias find='fd'
alias ls='eza --icons --group-directories-first'
alias ll='eza -l --icons'
alias la='eza -la --icons'
alias l='la'

# =============================================================================
# 8. GCP SDK
# =============================================================================
if [ -f "$BREW_PREFIX/share/google-cloud-sdk/path.zsh.inc" ]; then
    source "$BREW_PREFIX/share/google-cloud-sdk/path.zsh.inc"
    source "$BREW_PREFIX/share/google-cloud-sdk/completion.zsh.inc"
fi

# =============================================================================
# 9. Git Extras Completion
# =============================================================================
if [[ -f "$BREW_PREFIX/opt/git-extras/share/git-extras/git-extras-completion.zsh" ]]; then
    source "$BREW_PREFIX/opt/git-extras/share/git-extras/git-extras-completion.zsh"
fi

# =============================================================================
# 10. Local Overrides (Not in Git)
# =============================================================================
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
