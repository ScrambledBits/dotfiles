{{- if eq .chezmoi.os "linux" -}}
#!/bin/sh
# Install Homebrew (Linuxbrew) if not present. Runs once per machine via chezmoi.
set -e

if command -v brew >/dev/null 2>&1; then
    echo "Homebrew already installed, skipping."
    exit 0
fi

# Install required build dependencies for the detected package manager
if command -v apt-get >/dev/null 2>&1; then
    echo "Installing build dependencies via apt..."
    sudo apt-get update -qq
    sudo apt-get install -y build-essential procps curl file git
elif command -v dnf >/dev/null 2>&1; then
    echo "Installing build dependencies via dnf..."
    sudo dnf groupinstall -y 'Development Tools'
    sudo dnf install -y procps-ng curl file git
elif command -v pacman >/dev/null 2>&1; then
    echo "Installing build dependencies via pacman..."
    sudo pacman -Sy --noconfirm base-devel procps-ng curl file git
else
    echo "WARNING: Unknown package manager — ensure curl, git, and build tools are installed."
fi

echo "Installing Homebrew..."
NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

# Add Homebrew to PATH for the remainder of this invocation.
# chezmoi runs scripts in a clean environment; shell profiles are not sourced.
if [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -f "$HOME/.linuxbrew/bin/brew" ]; then
    eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
fi

echo "Homebrew installed."
{{- end }}
