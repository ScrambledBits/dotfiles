# direnv configuration
# https://direnv.net/

# Load mise when entering directories
use_mise() {
    eval "$(mise hook-env)"
}

# AWS profile switching
use_aws_profile() {
    export AWS_PROFILE="$1"
}

# GCP project switching
use_gcp_project() {
    export CLOUDSDK_CORE_PROJECT="$1"
}

# Terraform workspace switching
use_tf_workspace() {
    export TF_WORKSPACE="$1"
}

# Show a warning if .envrc is not yet allowed
log_status "direnv loaded. Run 'direnv allow' to activate per-project environments."
